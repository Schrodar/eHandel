// prisma/schema.prisma
generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    // directUrl is used by prisma migrate / prisma db push so DDL bypasses pgbouncer
    directUrl = env("DIRECT_URL")
}

// Using strings for priceClass and season for initial flexible seeding

model Color {
    id   String  @id
    name String
    hex  String?

    variants ProductVariant[]
}

model Category {
    id   String @id
    name String

    products Product[]
}

model Material {
    id   String @id
    name String

    products Product[]
}

model Product {
    id          String   @id // stable string id from JSON (e.g. "w-001")
    slug        String   @unique // stable unique slug for URLs/SEO
    name        String
    description String?
    categoryId  String
    category    Category @relation(fields: [categoryId], references: [id])

    materialId String
    material   Material @relation(fields: [materialId], references: [id])

    priceInCents Int?
    priceClass   String @default("standard")
    season       String @default("all")

    // Representative variant for product card images and default price
    defaultVariantId String?         @unique
    defaultVariant   ProductVariant? @relation("defaultVariant", fields: [defaultVariantId], references: [id])

    attributes Json?
    published  Boolean @default(true)

    variants ProductVariant[] @relation("productVariants")

    @@index([categoryId])
    @@index([materialId])
    @@index([defaultVariantId])
}

model ProductVariant {
    id        String  @id // stable string id from JSON, or you can use sku as id later
    sku       String  @unique // REQUIRED for commerce
    productId String
    product   Product @relation("productVariants", fields: [productId], references: [id], onDelete: Cascade)

    colorId String?
    color   Color?  @relation(fields: [colorId], references: [id])

    size         String? // legacy: kept for backward-compat during migration; use VariantSize going forward

    images       Json? // deprecated: use VariantImage instead
    priceInCents Int? // fallback price for all sizes; overridden per size in VariantSize
    stock        Int     @default(0) // legacy stock; kept for compat – sum/min managed via VariantSize
    attributes   Json?
    active       Boolean @default(true)

    variantImages VariantImage[]
    sizes         VariantSize[]  // child size-inventory rows

    // Backreference for when this variant is set as default
    defaultForProduct Product? @relation("defaultVariant")

    @@index([productId])
    @@index([colorId])
}

/// Size-level inventory row attached to a visual variant (e.g. color).
/// Replaces having one full ProductVariant per size.
model VariantSize {
    id           String         @id @default(cuid())
    variantId    String
    variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

    size         String         // "XS" | "S" | "M" | "L" | "XL" | "XXL" | …
    sku          String         @unique // e.g. "TSHIRT-WHITE-M"
    stock        Int            @default(0)
    priceInCents Int?           // override; null = inherit from ProductVariant.priceInCents
    active       Boolean        @default(true)

    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt

    @@unique([variantId, size])  // one row per color+size
    @@index([variantId])
}



// ─── Discount / Coupon system ─────────────────────────────────────────────────

enum DiscountScope {
    GLOBAL    // applies to entire cart
    CATEGORY  // applies to items whose product.categoryId matches
    PRODUCT   // applies to all variants of a specific product
    VARIANT   // applies to exactly one variant
}

enum DiscountType {
    PERCENT        // value = 1–100 (%)
    AMOUNT         // value = öre
    FREE_SHIPPING  // value ignored; discount = shippingCost
}

enum DiscountUsageType {
    UNLIMITED   // e.g. campaign code FIRST10
    SINGLE_USE  // e.g. unique printed voucher
    MAX_USES    // shared code with a cap (maxUses)
}

/** Describes the rules of a discount campaign. One drive → many codes. */
model DiscountDrive {
    id            String         @id @default(cuid())
    name          String
    scopeType     DiscountScope
    categoryId    String?        // set when scopeType=CATEGORY
    productId     String?        // set when scopeType=PRODUCT
    variantId     String?        // set when scopeType=VARIANT
    discountType  DiscountType
    value         Int            // PERCENT 1–100, AMOUNT öre, FREE_SHIPPING 0
    minOrderValue Int?           // min eligible subtotal in öre
    active        Boolean        @default(true)
    createdAt     DateTime       @default(now())

    codes DiscountCode[]

    @@index([active])
}

/** A code customers type in. Points to a DiscountDrive for the actual rules. */
model DiscountCode {
    id        String             @id @default(cuid())
    code      String             @unique
    driveId   String
    drive     DiscountDrive      @relation(fields: [driveId], references: [id], onDelete: Cascade)
    usageType DiscountUsageType
    maxUses   Int?               // only relevant when usageType=MAX_USES
    usedCount Int                @default(0)
    usedAt    DateTime?          // set on first use (SINGLE_USE)
    createdAt DateTime           @default(now())

    @@index([driveId])
    @@index([code])
}

enum CheckoutOrderStatus {
    CREATED
    AUTHORIZED
    CAPTURED
    FULFILLED
    CANCELLED
    REFUNDED
    PENDING_PAYMENT  // payment failed; customer can retry on same order
}

enum PaymentStatus {
    PENDING
    AUTHORIZED
    CAPTURED
    CANCELLED
    REFUNDED
    FAILED
}

enum OrderStatus {
    NEW
    READY_TO_PICK
    PICKING
    PACKED
    SHIPPED
    COMPLETED
    CANCELLED
}

model Order {
    id              String          @id @default(cuid())
    orderNumber     String          @unique // human-readable ORDER-YYYY-0001
    publicToken     String          @unique // random 64-char hex; required for public polling (no-PII)
    status          CheckoutOrderStatus @default(CREATED)
    providerOrderId String?         @unique
    providerPaymentId String?
    amountTotal     Int?
    shippingAddress Json?
    provider String @default("STRIPE")
    klarnaOrderId   String?         @unique
    paymentStatus   PaymentStatus   @default(PENDING)
    orderStatus     OrderStatus     @default(NEW)
    customerEmail String
    customerName  String
    customerPhone String?

    shippingAddressLine1 String
    shippingAddressLine2 String?
    shippingPostalCode   String
    shippingCity         String
    shippingCountry      String
    shippingCarrier      String?
    shippingTracking     String?

    billingAddressLine1 String?
    billingAddressLine2 String?
    billingPostalCode   String?
    billingCity         String?
    billingCountry      String?

    subtotal Int
    shipping Int
    discount Int         // total discount in öre
    tax      Int
    total    Int
    currency String
    appliedDiscountCode String?  // snapshot of code at time of order
    appliedDriveId      String?  // snapshot of drive id

    createdAt    DateTime  @default(now())
    authorizedAt DateTime?
    capturedAt   DateTime?
    shippedAt    DateTime?
    updatedAt    DateTime  @updatedAt

    confirmationEmailSentAt DateTime? // Set when order confirmation email is sent; used for idempotent email dispatch
    shippedEmailSentAt      DateTime? // Set when shipping notification email is sent; used for idempotent dispatch

    items  OrderItem[]
    events OrderEvent[]

    @@index([provider, status])
    @@index([klarnaOrderId])
    @@index([paymentStatus])
    @@index([orderStatus])
}

model OrderItem {
    id          Int     @id @default(autoincrement())
    orderId     String
    order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
    productId   String?
    variantId   String?
    productName String
    variantName String?
    sku         String?
    quantity    Int
    unitPrice   Int
    lineTotal   Int
    snapshotName String?
    snapshotUnitAmount Int?
    snapshotImageUrl String?
}

// Media library: folder hierarchy
model Folder {
    id         String        @id @default(cuid())
    name       String
    parentId   String?
    parent     Folder?       @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
    children   Folder[]      @relation("FolderTree")
    assetLinks AssetFolder[]
    createdAt  DateTime      @default(now())
    updatedAt  DateTime      @updatedAt

    @@index([parentId])
}

// Media library: assets (images, files)
model Asset {
    id        String         @id @default(cuid())
    type      String         @default("image") // image, video, etc.
    status    String         @default("ready") // ready | processing | failed
    url       String
    width     Int?
    height    Int?
    alt       String?
    folders   AssetFolder[]
    variants  VariantImage[]
    createdAt DateTime       @default(now())
    updatedAt DateTime       @updatedAt

    @@index([status])
}

// Media library: many-to-many Asset <-> Folder (assets can be in multiple folders)
model AssetFolder {
    assetId   String
    folderId  String
    asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
    folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())

    @@id([assetId, folderId])
    @@index([folderId])
}

// Variant gallery: many-to-many ProductVariant <-> Asset (with sortOrder + role)
model VariantImage {
    variantId String
    assetId   String
    role      String         @default("secondary") // primary | secondary
    sortOrder Int            @default(0)
    variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
    asset     Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
    createdAt DateTime       @default(now())

    @@id([variantId, assetId])
    @@unique([variantId, role]) // Only one primary per variant
    @@index([variantId, sortOrder])
    @@index([assetId])
}

// ─── Outbox ───────────────────────────────────────────────────────────────────

enum OrderEventType {
    ORDER_PAID
    ORDER_SHIPPED
}

model OrderEvent {
    id             String          @id @default(cuid())
    type           OrderEventType
    orderId        String
    order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
    payload        Json
    idempotencyKey String          @unique
    createdAt      DateTime        @default(now())
    processedAt    DateTime?
    attempts       Int             @default(0)
    lastError      String?
    lockedAt       DateTime?       // Lease-lock timestamp
    lockedBy       String?         // Processor instance id that holds the lock

    @@index([processedAt, createdAt])
    @@index([type, processedAt])
    @@index([orderId])
}
